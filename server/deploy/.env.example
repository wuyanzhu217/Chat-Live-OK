# Copy to .env:  cp .env.example .env
#
# SRS WebRTC/WHIP requires CANDIDATE = IP or hostname reachable by browsers.
# Linux dev: use your LAN IP (not 127.0.0.1) for Web/WHIP from other devices.
SRS_CANDIDATE=127.0.0.1

# Postgres
POSTGRES_USER=chatlive
POSTGRES_PASSWORD=chatlive_dev
POSTGRES_DB=chatlive

# MinIO
MINIO_ROOT_USER=chatlive
MINIO_ROOT_PASSWORD=chatlive_dev_minio
MINIO_BUCKET=chatlive-media
# Same-origin HTTPS path via nginx /media/ proxy (required for mobile mixed-content)
MINIO_PUBLIC_URL=https://127.0.0.1:8888/media

# coturn (dev static credentials) — resolve-turn-conf.sh writes turnserver.conf
TURN_SECRET=chatlive_turn_dev_secret
TURN_REALM=chatlive.local
TURN_HOST=127.0.0.1
TURN_PORT=3478
# Private NIC on cloud VM (hostname -I first token). Required for relay-ip / external-ip mapping.
# Example Aliyun ECS: TURN_INTERNAL_IP=172.22.162.225 when public IP is elastic-mapped.
TURN_INTERNAL_IP=

# Cloud security group — required for mobile video (calls + live):
#   8888/TCP, 8443/TCP   HTTPS/WSS gateway
#   80/TCP               Let's Encrypt http-01 (TLS_DOMAIN)
#   3478/UDP+TCP         coturn STUN/TURN signaling
#   49160-49200/UDP      coturn TURN relay media (1v1 video across NAT)
#   8000/UDP             SRS WebRTC media (WHIP/WHEP live streaming)

# Production TLS (Let's Encrypt) — eliminates iOS WSS blocking on self-signed certs.
# Requires DNS A record: TLS_DOMAIN -> server public IP. Browse https://TLS_DOMAIN:8888 (not IP).
# TLS_DOMAIN=
# TLS_EMAIL=admin@example.com

# Keycloak (OIDC — default auth, make dev-up)
KEYCLOAK_HTTP_PORT=8081
# Browser gateway: HTTP :8888 redirects to HTTPS :8443
KEYCLOAK_GATEWAY_PORT=8888
KEYCLOAK_HTTPS_PORT=8888
KEYCLOAK_HOSTNAME=127.0.0.1
KEYCLOAK_REALM=chatlive
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_dev
KEYCLOAK_CLIENT_ID_WEB=chatlive-web
KEYCLOAK_CLIENT_ID_DESKTOP=chatlive-desktop

# chatlive-server: validate tokens from Keycloak (not self-signed JWT)
KEYCLOAK_ISSUER=
KEYCLOAK_JWKS_URI=https://127.0.0.1:8888/auth/realms/chatlive/protocol/openid-connect/certs
KEYCLOAK_PUBLIC_URL=https://127.0.0.1:8888/auth

# Via nginx gateway (alternative for clients behind :8888 — redirects to :8443)
# KEYCLOAK_PUBLIC_URL=https://127.0.0.1:8443/auth
